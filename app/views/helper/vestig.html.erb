<div id='main'>
  <%= javascript_include_tag "application" %>
  <%= javascript_include_tag 'helper' %>
  <div class='site'>
    <%= stylesheet_link_tag 'helper' %>
    <div class='helperpop' id='gapsize'>
      <%= render :partial => 'markup_warn' %>
      <h3>Enter Extent of Vestig Gap and Vestig Type</h3>
      <h4>Valid values: e.g. 2 / c.3 / blank</h4>
      <div id='extent_left'>
        <input class='choosetext' id='vestig_value' size='07' type='text'>Extent</input>
      </div>
      <div id='type_left'>
        <input checked='' class='vestig_radio' id='character' name='vestig_type' onclick='checktypevestig(this.id)' type='radio' value='character'>Character</input>
        <br/>
        <input class='vestig_radio' id='line' name='vestig_type' onclick='checktypevestig(this.id)' type='radio' value='line'>Line</input>
      </div>
      <div id='low_left'>
        <form name='vestig'>
          <input class='vestiglow_check_c' disabled='true' id='vestiglow' name='vestiglow_check_n' type='checkbox' value='vestiglow'>Cert Low (line only)</input>
        </form>
      </div>
      <div id='button_left'>
        <button onclick='insertVestig()' type='button'>Insert</button>
        &nbsp
        <button onclick='closeHelper()' type='button'>Close</button>
      </div>
    </div>
  </div>
</div>
