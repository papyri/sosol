<div id='main'>
  <%= javascript_include_tag "application" %>
  <%= javascript_include_tag 'helper' %>
  <div class='site'>
    <%= stylesheet_link_tag 'helper' %>
    <div class='helperpop' id='gapsize'>
      <%= render :partial => 'markup_warn' %>
      <br>
      <br>
      <form name='abbrev'>
        <input checked='' class='abbrev_radio' id='abbrev_expan' name='abbrev_type_n' onclick='checktypeabbrev(this.id)' type='radio' value='expan'>Expansion, e.g. στρ(ατηγός) / (ἔτους) / στρ(ατηγ)</input>
        <br>
        <br>
        <input class='choosetext greek' id='expan_text' size='25' type='text'>: enter στρ(ατηγός) / στρ(ατηγ)</input>
        <div id='abbrev_incomplete'>
          <input class='abbrev2sp_cb' id='abbrev2sp' name='abbrev2sp_cb' type='checkbox' value='abbrev2sp'>Incomplete expansion, e.g. στρ(ατηγ&nbsp&nbsp)</input>
        </div>
        <br>
        <br>
        <input class='abbrev_radio' id='abbrev_abbr' name='abbrev_type_n' onclick='checktypeabbrev(this.id)' type='radio' value='abbr'>Unexpanded abbreviation, e.g. στρατ(  )</input>
        <br>
        <br>
        <input class='choosetext greek' disabled='true' id='abbr_text' size='25' type='text'>: enter στρατ</input>
        <br>
        <br>
        <br>
        <input class='abbrevlow_check_c' id='abbrevlow' name='abbrevlow_check_n' type='checkbox' value='abbrevlow'>Uncertain?</input>
        <br>
        <br>
        <button onclick='insertAbbrev()' type='button'>Insert</button>
        &nbsp
        <button onclick='closeHelper()' type='button'>Close</button>
      </form>
    </div>
  </div>
</div>
