<h1>
  User Admin Privileges
</h1>
<% for user in @users %>
  <div class='user_admins'>
    <div class='user_name'>
      <%= h user.name %>
    </div>
    <div class='checkbox_container'>
      <%= check_box_tag "name", "1", user.is_master_admin, { :disabled => true } %>
      Master Admin
    </div>
    <div class='checkbox_container'>
      <%= check_box_tag "name", "1", user.is_community_master_admin, { :disabled => true } %>
      Community Master Admin
    </div>
    <div class='checkbox_container'>
      <%= check_box_tag "name", "1", user.admin, { :disabled => true } %>
      Admin
    </div>
    <div class='checkbox_container'>
      <%= check_box_tag "name", "1", user.developer, { :disabled => true } %>
      Developer
    </div>
    <%= link_to "Edit", :controller => :user, :action => :edit_user_admins, :user_id => user.id %>
  </div>
<% end %>
