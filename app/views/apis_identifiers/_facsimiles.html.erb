<div id='multi_facsimile'>
  <ul id='multiItems_facsimile'>
    <li class='facsimile'>
      <%= render :partial => 'apis_identifiers/label', :locals => {:key => :surfaceGrpId} %>
      <%= text_field_tag 'apis_identifier_surfaceGrpId', '', :class => 'observechange apis apis_identifier_surfaceGrpId' %>
      <%= render :partial => 'apis_identifiers/label', :locals => {:key => :surfaceType1} %>
      <%= text_field_tag 'apis_identifier_surfaceType', '', :class => 'observechange apis apis_identifier_surfaceType' %>
      <%= render :partial => 'apis_identifiers/label', :locals => {:key => :facsUrl} %>
      <%= text_field_tag 'apis_identifier_facsUrl', '', :class => 'observechange apis apis_identifier_facsUrl' %>
      <%= render :partial => 'apis_identifiers/label', :locals => {:key => :surfaceType2} %>
      <%= text_field_tag 'apis_identifier_surfaceType2', '', :class => 'observechange apis apis_identifier_surfaceType2' %>
      <%= render :partial => 'apis_identifiers/label', :locals => {:key => :facsUrl} %>
      <%= text_field_tag 'apis_identifier_facsUrl2', '', :class => 'observechange apis apis_identifier_facsUrl2' %>
      <span class='delete' <%= tag_options({:onclick => 'multiRemove(this.parentNode)', :title => I18n.t('tooltip.multiDelete')}, false) %>>x</span>
      <span class='move' <%= tag_options({:title => I18n.t('tooltip.multiMove')}, false) %>>o</span>
    </li>
  </ul>
  <p class='add' id='multiPlus_facsimile'>
    <span <%= tag_options({:onclick => "multiAddFacsimiles()", :title => I18n.t('tooltip.multiAdd')}, false) %>><%= I18n.t('label.multiAdd') %></span>
  </p>
  <%= javascript_tag "Sortable.create(document.getElementById('multiItems_facsimile'), {direction: 'horizontal', handle: '.move'});" %>
</div>
