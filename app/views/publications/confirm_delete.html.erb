<div class='site' id='main'>
  <h2>
    <%= @publication.title %>
    <% if !@publication.status.nil? && @publication.status != '' %>
      <%= "(#{@publication.status})" %>
    <% end %>
  </h2>
  <%# render :partial => "common/flash_all" %>
  <h2>
    Are You Sure You Want to Delete this publication? This action will only delete your copy of this publication, but cannot be undone.
  </h2>
  <h1>
    <%= button_to "Delete", @publication, :method => :delete %>
    <%= "or" %>
    <%= link_to "Cancel", @publication %>
  </h1>
</div>
