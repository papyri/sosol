<div id='main'>
  <%#= render :partial => 'identifiers/edit_bar' %>
  <div class='site'>
    <%# render :partial => "common/flash_all" %>
    <div id='rename'>
      <h1>
        Renaming identifier
        <%= @identifier.title %>
        from publication
        <%= @identifier.publication.title %>
        <br>
      </h1>
      <h2>
        <%= @identifier.class %>
        <%= @identifier.name %>
      </h2>
      <br>
      <p>Other identifiers currently associated with this publication:</p>
      <ul>
        <% (@identifier.publication.identifiers - [@identifier]).each do |i| %>
          <li><%= i.name %></li>
        <% end %>
      </ul>
      <h3>
        <br>
      </h3>
      <%= form_for @identifier, :url => { :action => "rename" } do |f| %>
        <%= f.error_messages %>
        <% if [DCLPMetaIdentifier, DCLPTextIdentifier].include? @identifier.class %>
          <div class='new_name_new_hybrid'>
            <label>New file name:</label>
            <%= text_field_tag :new_name, @identifier.name, :class => :comment, :size => '80', :disabled => !@identifier.mutable? %>
            <%= "(#{I18n.t('dclp.help.renameNewName')})" %>
            <br>
            <label>New dclp-hybrid name:</label>
            <%= text_field_tag :new_hybrid, @identifier.hybrid, :class => :comment, :size => '80', :disabled => !@identifier.mutable? %>
            <%= "(#{I18n.t('dclp.help.renameNewHybrid')})" %>
          </div>
        <% else %>
          <label>New name:</label>
          <%= text_field_tag :new_name, @identifier.name, :class => :comment, :size => '80', :disabled => !@identifier.mutable? %>
          <% unless @identifier.needs_rename? %>
            <br>
            <br>
            <%= check_box_tag :set_dummy_header %>
            Leave dummy header in original file
          <% end %>
        <% end %>
        <br>
        <br>
        <%= f.submit "Rename", :class => 'save', :disabled => !@identifier.mutable? %>
      <% end %>

    </div>
  </div>
</div>
