<div class='commit'>
  <div class='body'>
    <div class='message'>
      <%= simple_format(commit[:message]) %>
    </div>
    <div class='author'>
      <%= commit[:author_name] %>
      <span class='type'>
        (author)
      </span>
    </div>
    <div class='date'>
      <%= commit[:authored_date] > 1.week.ago ? "#{time_ago_in_words(commit[:authored_date])} ago" : commit[:authored_date].strftime("%B %d, %Y") %>
    </div>
    <% if commit[:author_name] != commit[:committer_name] %>
      <div class='author'>
        <%= commit[:committer_name] %>
        <span class='type'>
          (committer)
        </span>
      </div>
      <div class='date'>
        <%= commit[:committed_date] > 1.week.ago ? "#{time_ago_in_words(commit[:committed_date])} ago" : commit[:committed_date].strftime("%B %d, %Y") %>
      </div>
    <% end %>
  </div>
  <div class='ids'>
    <ul>
      <% unless prev_commit.nil? %>
        <li>
          prev
          <%= link_to prev_commit[0..6], url_for(:action => 'show_commit', :commit_id => prev_commit, :id => identifier.id, :publication_id => identifier.publication.id) %>
        </li>
      <% end %>
      <%# %li %>
      <%# commit %>
      <%# = link_to commit[:id][0..6], url_for(:action => 'show_commit', :commit_id => commit[:id], :id => identifier.id, :publication_id => identifier.publication.id) %>
      <% unless next_commit.nil? %>
        <li>
          next
          <%= link_to next_commit[0..6], url_for(:action => 'show_commit', :commit_id => next_commit, :id => identifier.id, :publication_id => identifier.publication.id) %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
