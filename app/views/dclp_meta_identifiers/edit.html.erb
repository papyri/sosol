<%= stylesheet_link_tag 'meta' %>
<div id='main'>
  <div class='site metaSite'>
    <%= render :partial => 'identifiers/header' %>
    <span class='swifty expandAll' id='expandAll'><%= I18n.t('label.expandAll') %></span>
    <span class='swifty collapseAll' id='collapseAll'><%= I18n.t('label.collapseAll') %></span>
    <div id='edit'>
      <%= form_for @identifier, :url => { :action => :update }, :html => { :autocomplete => :off } do |f| %>
        <%= f.error_messages %>
        <h4 class='category edition'>
          <a name='Edition'><%= I18n.t('dclp.legend.edition') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <%= render :partial => 'dclp_meta_identifiers/edition' %>
          <div class='clear'></div>
          <%= render :partial => 'dclp_meta_identifiers/illustration' %>
          <div class='clear'></div>
          <span class='swifty quickSave'><%= I18n.t('label.quickSave') %></span>
          <span class='swifty addEdition'><%= I18n.t('dclp.label.addEdition') %></span>
        </div>
        <h4 class='category work'>
          <a name='Edition'><%= I18n.t('dclp.legend.work') %></a>
        </h4>
        <div class='editbox' style='display: block;'>
          <%= label_tag 'titleStmt', I18n.t('dclp.label.titleStmt'), :class => 'meta titleStmt displayName', :title => @identifier.configuration.xpath(:titleStmt) %>
          <%= render :partial => 'hgv_meta_identifiers/text_field', :locals => { :key => :titleStmt } %>
          <div class='clear'></div>
          <%= label_tag 'archiveName', I18n.t('dclp.label.archiveName'), :class => 'meta archiveName', :title => @identifier.configuration.xpath(:archiveName) %>
          <%= render :partial => 'hgv_meta_identifiers/text_field', :locals => { :key => :archiveName } %>
          <div class='clear'></div>
          <%= label_tag 'archiveLink', I18n.t('dclp.label.archiveLink'), :class => 'meta archiveLink', :title => @identifier.configuration.xpath(:archiveLink) %>
          <%= render :partial => 'hgv_meta_identifiers/text_field', :locals => { :key => :archiveLink } %>
          <div class='clear'></div>
          <%= render :partial => 'dclp_meta_identifiers/contentText' %>
          <div class='clear'></div>
          <%= render :partial => 'dclp_meta_identifiers/work' %>
          <div class='clear'></div>
          <span class='swifty quickSave'><%= I18n.t('label.quickSave') %></span>
          <span class='swifty addWork'><%= I18n.t('dclp.label.addWork') %></span>
        </div>
        <h4 class='category object'>
          <a name='Edition'><%= I18n.t('dclp.legend.object') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <%= render :partial => 'dclp_meta_identifiers/object' %>
          <div class='clear'></div>
          <div class='swifty quickSave'><%= I18n.t('label.quickSave') %></div>
        </div>
        <h4 class='category general'>
          <a name='General&lt;'><%= I18n.t('dclp.legend.general') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <%= label_tag 'mp3', I18n.t('dclp.label.mp3'), :class => 'meta mp3', :title => @identifier.configuration.xpath(:mp3) %>
          <%= render :partial => 'hgv_meta_identifiers/text_field', :locals => { :key => :mp3 } %>
          <div class='clear'></div>
          <%= text_area_tag 'hgv_meta_identifier[' + :notes.to_s + ']', @identifier.non_database_attribute[:notes], :disabled => !@identifier.mutable?, :class => 'observechange' %>
          <div class='clear'></div>
          <div class='swifty quickSave'><%= I18n.t('label.quickSave') %></div>
        </div>
        <h4 class='category date'>
          <a name='Date'><%= I18n.t('meta.legend.date') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <%= render :partial => 'hgv_meta_identifiers/date' %>
          <div class='clear'></div>
          <span class='swifty quickSave'><%= I18n.t('label.quickSave') %></span>
          <span class='swifty datePreview' <%= tag_options({:onclick => "new Ajax.Request('#{url_for(:controller => 'hgv_meta_identifiers', :action => 'get_date_preview', :only_path => true)}?' + $$('form.edit_dclp_meta_identifier')[0].serialize(), {asynchronous:true, evalScripts:true, parameters:Form.serialize(this)}); return false;"}, false) %>><%= I18n.t('meta.label.datePreview') %></span>
        </div>
        <h4 class='category mentionedDate'>
          <a name='mentionedDate'><%= I18n.t('meta.legend.mentionedDate') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <%= render :partial => 'hgv_meta_identifiers/mentioned_date' %>
          <div class='clear'></div>
          <span class='swifty quickSave'><%= I18n.t('label.quickSave') %></span>
        </div>
        <h4 class='category provenance'>
          <a name='Provenance'><%= I18n.t('meta.legend.provenance') %></a>
        </h4>
        <div class='editbox' style='display: none;'>
          <p id='geoPreview'>
            <%= @identifier.non_database_attribute[:origPlace] %>
          </p>
          <span class='swifty geoPreview' <%= tag_options({:onclick => "new Ajax.Request('#{url_for(:controller => 'hgv_meta_identifiers', :action => 'get_geo_preview', :only_path => true)}', {asynchronous:true, evalScripts:true, parameters:$$('form.edit_dclp_meta_identifier')[0].serialize()}); return false;"}, false) %>><%= I18n.t('meta.label.geoPreview') %></span>
          <hr>
          <%= render :partial => 'hgv_meta_identifiers/provenance' %>
          <div class='clear'></div>
          <span class='swifty quickSave'><%= I18n.t('label.quickSave') %></span>
          <span class='swifty addProvenance'><%= I18n.t('meta.label.addProvenance') %></span>
          <span class='swifty showReferenceList' id='toggleReferenceList'><%= I18n.t('meta.label.showReferenceList') %></span>
        </div>
        <div class='controlPanel'>
          <%= render :partial => 'identifiers/edit_commit', :locals => { :f => f, :identifier => @identifier, :where_at => :bottom } %>
          <%= hidden_field_tag 'expansionSet', flash[:expansionSet] %>
        </div>
      <% end %>

    </div>
  </div>
</div>
<%= javascript_include_tag 'edit_mask' %>
<%= javascript_include_tag 'meta' %>
<%= javascript_include_tag 'dclp' %>
<%= javascript_include_tag 'confirm' %>
